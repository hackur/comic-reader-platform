{
  "name": "@comics-platform/comic-extractor-images",
  "version": "0.1.0",
  "description": "Loose-image / directory / single-image extractor for the comics platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["comics", "images", "directory", "extractor"],
  "author": "Comics Platform Contributors",
  "license": "MIT",
  "dependencies": {
    "@comics-platform/comic-core": "workspace:*"
  },
  "devDependencies": {
    "happy-dom": "^15.11.7",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
